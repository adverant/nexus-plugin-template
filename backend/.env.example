# {{PLUGIN_DISPLAY_NAME}} Configuration

# Server Configuration
PORT=9099
WS_PORT=9100
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# JWT Configuration (must match nexus-auth)
JWT_SECRET=your-secret-key-change-in-production

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Service Endpoints
GRAPHRAG_ENDPOINT=http://localhost:8090
MAGEAGENT_ENDPOINT=http://localhost:8080

# Feature Flags
ENABLE_WEBSOCKET=true

# Logging
LOG_LEVEL=info
