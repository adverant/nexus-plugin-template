# Plugin Identity
NEXT_PUBLIC_PLUGIN_ID=your-plugin-id

# Gateway WebSocket URL (public — browser connects directly)
NEXT_PUBLIC_GATEWAY_WS_URL=wss://gateway.adverant.ai

# TSE service URL (server-side only — never exposed to browser)
TSE_SERVICE_URL=http://nexus-tse:8095

# Internal service key for BFF → TSE communication (server-side only)
INTERNAL_SERVICE_KEY=your-service-key
