# {{PLUGIN_DISPLAY_NAME}} Configuration

# Server
PORT=8080
HOST=0.0.0.0
NODE_ENV=development
PLUGIN_NAME={{PLUGIN_NAME}}
PLUGIN_VERSION=1.0.0

# Database (optional - plugin works without it using in-memory responses)
# DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus

# Nexus Platform Integration (optional - enables self-registration)
# NEXUS_API_URL=https://api.adverant.ai
# NEXUS_API_KEY=your-nexus-api-key

# Nexus Internal Services (set automatically in K8s)
# NEXUS_GRAPHRAG_URL=http://nexus-graphrag.nexus.svc.cluster.local:9000
# NEXUS_MAGEAGENT_URL=http://nexus-mageagent.nexus.svc.cluster.local:9010
# NEXUS_SANDBOX_URL=http://nexus-sandbox.nexus.svc.cluster.local:9020
# NEXUS_FILEPROCESS_URL=http://nexus-fileprocess.nexus.svc.cluster.local:9030
# NEXUS_SKILLS_ENGINE_URL=http://nexus-skills-engine.nexus.svc.cluster.local:9040

# LLM Access (optional)
# OPENROUTER_API_KEY=your-openrouter-key

# Database Pool Configuration
# DB_POOL_MAX=10
# DB_IDLE_TIMEOUT=30000
# DB_CONNECTION_TIMEOUT=5000
